---
import type { GuideEntry } from "@/lib/content";
import { Separator } from "@/components/ui/separator";
import { getGuideHref } from "@/lib/content";

interface Props {
  guides: GuideEntry[];
}

const { guides } = Astro.props;
---

<footer class="mx-auto max-w-7xl px-6 pb-10 lg:px-8">
  <Separator />
  <div class="flex flex-wrap items-center justify-between gap-4 py-6 text-sm text-foreground/60">
    <p>Rent Some Hash</p>
    <div class="flex flex-wrap gap-4">
      <a href="/" class="transition-colors hover:text-foreground">Home</a>
      <a href="/calculator/" class="transition-colors hover:text-foreground">Calculator</a>
      {guides.map((guide) => (
        <a href={getGuideHref(guide)} class="transition-colors hover:text-foreground">
          {guide.data.navLabel}
        </a>
      ))}
    </div>
  </div>
</footer>
