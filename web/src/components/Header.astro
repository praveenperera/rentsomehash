---
import type { GuideEntry } from "@/lib/content";
import { buttonVariants } from "@/components/ui/button";
import ThemeToggle from "@/components/ThemeToggle";

interface Props {
  guides: GuideEntry[];
  currentPath: string;
}

const { guides, currentPath } = Astro.props;
const navLinks = [
  { href: "/", label: "Home" },
  ...guides.map((guide) => ({
    href: `/guides/${guide.data.slug}/`,
    label: guide.data.navLabel,
  })),
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-border/70 bg-background/85 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4 lg:px-8">
    <a href="/" class="inline-flex items-center gap-3">
      <span class="inline-flex size-2 bg-primary"></span>
      <span class="font-heading text-sm tracking-[-0.05em]">Rent Some Hash</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-sm transition-colors hover:text-foreground",
            currentPath === link.href ? "text-foreground" : "text-foreground/60",
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <a href="/guides/braiins-ocean/" class={buttonVariants({ variant: "outline", size: "sm" })}>
        Open guide
      </a>
      <ThemeToggle client:load />
    </div>

    <details class="md:hidden">
      <summary class:list={[buttonVariants({ variant: "outline", size: "sm" }), "list-none [&::-webkit-details-marker]:hidden"]}>
        Menu
      </summary>
      <div class="absolute right-6 top-16 min-w-56 border border-border/70 bg-background/95 p-4 shadow-2xl backdrop-blur-sm">
        <nav class="space-y-3">
          {navLinks.map((link) => (
            <a href={link.href} class="block text-sm text-foreground/74 transition-colors hover:text-foreground">
              {link.label}
            </a>
          ))}
        </nav>
        <div class="mt-4 pt-4 border-t border-border/70">
          <ThemeToggle client:load />
        </div>
      </div>
    </details>
  </div>
</header>
