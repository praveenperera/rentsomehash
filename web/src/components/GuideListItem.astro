---
import { ArrowRightIcon } from "@phosphor-icons/react";

import { Badge } from "@/components/ui/badge";
import type { GuideEntry } from "@/lib/content";
import { getGuideHref, getReadingTime } from "@/lib/content";

interface Props {
  guide: GuideEntry;
}

const { guide } = Astro.props;
---

<a href={getGuideHref(guide)} class="group block px-5 py-5 transition-colors hover:bg-muted/30">
  <div class="flex flex-wrap items-center gap-3">
    <Badge variant={guide.data.kind === "primary" ? "default" : "outline"}>
      {guide.data.kind === "primary" ? "Main route" : "Alternative"}
    </Badge>
    <p class="text-[11px] uppercase tracking-[0.2em] text-muted-foreground">
      {getReadingTime(guide)}
    </p>
  </div>
  <div class="mt-3 flex items-start justify-between gap-4">
    <div class="space-y-2">
      <h3 class="text-lg font-heading tracking-[-0.04em]">{guide.data.title}</h3>
      <p class="max-w-xl text-sm leading-7 text-foreground/74">
        {guide.data.summary}
      </p>
    </div>
    <ArrowRightIcon
      className="mt-1 size-4 shrink-0 text-muted-foreground transition-transform group-hover:translate-x-1 group-hover:text-foreground"
      aria-hidden="true"
    />
  </div>
</a>
