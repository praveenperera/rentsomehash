---
import { ArrowRightIcon } from "@phosphor-icons/react";

import Footer from "@/components/Footer.astro";
import { HashpowerCalculator } from "@/components/HashpowerCalculator";
import Header from "@/components/Header.astro";
import { Badge } from "@/components/ui/badge";
import { buttonVariants } from "@/components/ui/button";
import { getGuides } from "@/lib/content";
import SiteLayout from "@/layouts/SiteLayout.astro";

const guides = await getGuides();
---

<SiteLayout
  title="Bitcoin Hashpower Calculator: Braiins vs Spot Bitcoin"
  description="Compare rented Braiins hashpower against buying spot bitcoin using live market data, expected SATS output, OCEAN timing, and liquidity warnings."
  ogImage="/images/rentsomehash-og-calculator.png"
>
  <Header guides={guides} currentPath={Astro.url.pathname} />

  <main class="pb-24">
    <section class="border-b border-border/70">
      <div class="mx-auto max-w-7xl px-6 pt-28 pb-14 lg:px-8">
        <div class="space-y-5">
          <Badge variant="outline" className="border-primary/25 bg-primary/10 text-primary">
            Expected value calculator
          </Badge>
          <h1 class="max-w-4xl text-4xl font-heading font-medium tracking-[-0.08em] text-balance sm:text-5xl">
            Compare renting hashpower with buying bitcoin outright
          </h1>
          <p class="max-w-3xl text-lg leading-8 text-foreground/76">
            Size the rental by capital or target speed, then compare the expected SATS result against
            buying spot bitcoin with the same spend.
          </p>
          <p class="max-w-3xl border-l border-primary/50 pl-4 text-sm leading-7 text-muted-foreground">
            This is an estimate, not a promise. It holds current difficulty and market price constant
            and does not predict variance, bid fills, pool payout timing edge cases, or future price
            moves.
          </p>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-14 lg:px-8">
      <HashpowerCalculator client:load />
    </section>

    <section class="border-t border-border/70">
      <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
        <div class="flex flex-wrap items-center justify-between gap-6">
          <div class="space-y-3">
            <h2 class="text-2xl font-heading tracking-[-0.06em]">
              Ready to set up?
            </h2>
            <p class="max-w-2xl text-base leading-8 text-foreground/74">
              Follow the step-by-step guides to get a DATUM node running and point Braiins
              hashpower at it.
            </p>
          </div>
          <a href="/#workflow" class={buttonVariants({ size: "lg" })}>
            View the guides
            <ArrowRightIcon className="size-4" aria-hidden="true" />
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer guides={guides} />
</SiteLayout>
